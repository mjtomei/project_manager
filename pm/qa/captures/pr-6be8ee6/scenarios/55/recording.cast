[35.625939, "o", "\u001b[40m\u001b[26;1H  \u001b[97m## Authoring tips\u001b[39m                                                                                \r\n                                                                                                   \r\n  \u001b[97m- For artifact recipes, the manifest format section is the most\u001b[39m                                  \r\n  \u001b[97m  load-bearing part вҖ” make it unambiguous so captures aren't opaque.\u001b[39m                             \r\n  \u001b[97m- Recipes can reference your project's own paths and tooling freely вҖ”\u001b[39m                            \r\n  \u001b[97m  the QA library is per-project. Only extract something into a recipe\u001b[39m                            \r\n  \u001b[97m  if you'll reuse it across multiple scenarios or PRs.\u001b[39m                                           \r\n  \u001b[97m- `pm qa list` shows existing recipes; `pm qa show <id>` prints any\u001b[39m                              \r\n  \u001b[97m  one of them. Browse a few before authoring something new вҖ” the\u001b[39m                                 \r\n  \u001b[97m  fastest "]
[35.62598, "o", "way to learn the shape is to read what's already there.\u001b[39m                                \r\n                                                                                                   \r\n                                                                                                   \u001b[49m\u001b[38;99H\u001b[1K\n\u001b[1K\u001b[37m\rв—Ҹ\u001b[39m Listing \u001b[1m2\u001b[m\u000f directoriesвҖҰ \u001b[37m(ctrl+o\u001b[39m \u001b[37mto\u001b[39m \u001b[37mexpand)\r\n \u001b[39m \u001b[37mвҺҝ\u001b[39m  \u001b[37m$\u001b[39m \u001b[37mls\u001b[39m \u001b[37m-la\u001b[39m \u001b[37m/workspace/pm-test-rec/pm/qa/\u001b[39m \u001b[37m2>&1;\u001b[39m \u001b[37mls\u001b[39m \u001b[37m-la\u001b[39m \u001b[37m/workspace/pm-test-rec/\u001b[39m \u001b[37m2>&1\u001b[39m              \u001b[41;99H\u001b[1K\u001b[31m\r\nВ·\u001b[39m \u001b[31mHarm\u001b[93moni\u001b[31mzingвҖҰ\u001b[39m \u001b[37m(9s\u001b[39m \u001b[37mВ·\u001b[39m \u001b[37mвҶ“\u001b[39m \u001b[37m317\u001b[39m \u001b[37mtokens\u001b[39m \u001b[37mВ·\u001b[39m \u001b[37mthinking\u001b[39m \u001b[37mwith\u001b[39m \u001b[37mmedium\u001b[39m \u001b[37meffort)\u001b[39m                                   \u001b[43;99H\u001b[1K\u001b[37m\r\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"]

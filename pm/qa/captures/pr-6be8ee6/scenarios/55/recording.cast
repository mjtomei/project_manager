[37.670213, "o", "\n                   \u001b[36mв”Ӯ\u001b[2C\u001b[97mName\u001b[52C\u001b[36mв”Ӯ\u001b[97m                    \r\n                   \u001b[36mв”Ӯ\u001b[2C\u001b[39m\u001b[100m \u001b[30m\u001b[107me\u001b[37m\u001b[100m.g. login-flow-setup\u001b[97m                               \u001b[39m \u001b[2C\u001b[36m\u001b[40mв”Ӯ\u001b[97m                    \r\n  \u001b[90m\u001b[1m\u001b[4m  Regression Test\u001b[m\u000f\u001b[36m\u001b[40mв”Ӯ\u001b[39m    \u001b[54C\u001b[36mв”Ӯ\u001b[97m                    \r\n  \u001b[90m  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\u001b[36mв”Ӯ\u001b[39m  \u001b[97mKind\u001b[39m                  \u001b[34C\u001b[36mв”Ӯ\u001b[97m                    \r\n  \u001b[90m\u001b[1mв–¶ reg-one: Test r\u001b[m\u000f\u001b[36m\u001b[40mв”Ӯ\u001b[39m  \u001b[97mв–ё Instruction\u001b[43C\u001b[36mв”Ӯ\u001b[97m                    \r\n  \u001b[90m\u001b[3m    t\u001b[m\u000f\u001b[97m\u001b[40m            \u001b[36mв”Ӯ\u001b[2C\u001b[97m  Regression test\u001b[39C\u001b[36mв”Ӯ\u001b[97m                    \r\n                   \u001b[36mв”Ӯ\u001b[2C\u001b[97m  Artifact recipe\u001b[39C\u001b[36mв”Ӯ\u001b[97m                    \r\n                   \u001b[36mв”Ӯ\u001b[58Cв”Ӯ\u001b[97m                    \r\n  \u001b[90m\u001b[1m\u001b[4m  Artifact Recipe\u001b[m\u000f\u001b[36m\u001b[40mв”Ӯ\u001b[39m  \u001b[37mвҶ‘вҶ“ change kind В· Enter create В· Esc cancel\u001b[14C\u001b[36mв”Ӯ\u001b[97m                    "]
[37.670223, "o", "\r\n  \u001b[90m  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\u001b[36mв”Ӯ\u001b[39m                        \u001b[34C\u001b[36mв”Ӯ\u001b[97m                    \r\n                   \u001b[36mв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\u001b[m\u000f\u001b[36m\u001b[40mв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\u001b[97m                    \r\n                                                                                                   \r\n                                                                                                   \r\n \u001b[90m Launched qa-item pane\u001b[97m                                                                            \r\n  \u001b[25C\u001b[90m                                                                      \u001b[97m  \r\n                                                                                                   \u001b[5;20H\u001b[36mв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"]
